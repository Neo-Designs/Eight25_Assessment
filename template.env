# ==========================================
# Website Audit Tool - Production Environment
# ==========================================

# 1. LLM API Keys (At least one is required)
# Gemini is the default fallback, OpenAI can be used as primary
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# 2. Database Configuration
# Using SQLite for local/App Runner instance. Use PostgreSQL URL for RDS.
DATABASE_URL=sqlite:///./audit_tool.db

# 3. Security (JWT Authentication)
# Generate a strong 64-character hex string (e.g., using `openssl rand -hex 32`)
JWT_SECRET_KEY=your_secure_random_jwt_secret_here
