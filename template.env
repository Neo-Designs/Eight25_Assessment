# ==========================================
# Website Audit Tool - Environment Template
# Copy to .env in repo root (recommended)
# ==========================================

# 1. LLM (Groq required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile
LLM_MAX_RETRIES=2

# 2. Database
# Local dev (SQLite):
DATABASE_URL=sqlite:///./audit_tool.db
# Production (Supabase PostgreSQL — append ?sslmode=require if needed):
# DATABASE_URL=postgresql://user:pass@host:6543/postgres

# 3. Security (JWT)
JWT_SECRET_KEY=your_secure_random_jwt_secret_here

# 4. CORS — comma-separated extra origins (Vercel URL, etc.)
# Example: https://your-app.vercel.app
CORS_ORIGINS=

# 5. Frontend API URL (local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# 6. Optional: enable hot reload for backend dev
UVICORN_RELOAD=false
