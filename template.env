# ==========================================
# Website Audit Tool - Environment Template
# Copy to .env in repo root or backend/
# ==========================================

# 1. LLM (Groq required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_NAME=llama3-70b-8192
LLM_MAX_RETRIES=2

# 2. Database
DATABASE_URL=sqlite:///./audit_tool.db

# 3. Security (JWT)
JWT_SECRET_KEY=your_secure_random_jwt_secret_here

# 4. CORS (comma-separated extra origins)
CORS_ORIGINS=

# 5. Frontend (for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
