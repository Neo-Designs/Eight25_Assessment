# ==========================================
# Website Audit Tool - Environment Template
# Copy to .env in repo root or backend/
# ==========================================

# 1. LLM API Keys (at least one required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini
GEMINI_MODEL_NAME=gemini-2.0-flash
LLM_MAX_RETRIES=2

# 2. Database
DATABASE_URL=sqlite:///./audit_tool.db

# 3. Security (JWT)
JWT_SECRET_KEY=your_secure_random_jwt_secret_here

# 4. CORS (comma-separated extra origins)
CORS_ORIGINS=

# 5. Frontend (for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000
